{
  "collections": {
    "m1-p13-nyavo-fitia.users": {
      "ns": "m1-p13-nyavo-fitia.users",
      "jsonSchema": {
        "bsonType": "object",
        "required": ["firebaseUid", "email", "role"],
        "properties": {
          "firebaseUid": { "bsonType": "string" },
          "username": { "bsonType": "string" },
          "name": { "bsonType": "string" },
          "email": {
            "bsonType": "string",
            "pattern": "^\\S+@\\S+\\.\\S+$"
          },
          "provider": {
            "enum": ["google", "github", "password"]
          },
          "role": { "enum": ["admin","shop","user"],"bsonType": "int" }
        }
      }
    },
    "m1-p13-nyavo-fitia.shops": {
      "ns": "m1-p13-nyavo-fitia.shops",
      "jsonSchema": {
        "bsonType": "object",
        "required": [
          "_id",
          "tenantId",
          "name",
          "shopRef"
        ],
        "properties": {
          "_id": {
            "bsonType": "objectId"
          },
          "tenantId": {
            "bsonType": "string",
            "description": "Required: Link to the User ID of the shop owner"
          },
          "boxId": {
            "bsonType": "string"
          },
          "name": {
            "bsonType": "string",
            "description": "Required: The display name of the shop"
          },
          "shopRef": {
            "bsonType": "string",
            "description": "Required: A unique internal reference code for the shop"
          }
        }
      }
    },
    "m1-p13-nyavo-fitia.boxes": {
      "ns": "m1-p13-nyavo-fitia.boxes",
      "jsonSchema": {
        "bsonType": "object",
        "required": [
          "_id",
          "boxId",
          "used"
        ],
        "properties": {
          "_id": {
            "bsonType": "objectId"
          },
          "boxId": {
            "bsonType": "string",
            "description": "Required & Autogenerated in Backend: The unique identifier for the unit."
          },
          "used": {
            "bsonType": "bool",
            "description": "Defaults to false in application logic."
          },
          "tenantId": {
            "bsonType": "string",
            "description": "Optional: Only present when used is true."
          }
        }
      }
    },
    "m1-p13-nyavo-fitia.products": {
      "ns": "m1-p13-nyavo-fitia.products",
      "jsonSchema": {
        "bsonType": "object",
        "required": [
          "_id",
          "productRef",
          "price",
          "name",
          "shopRef",
          "physicalStock"
        ],
        "properties": {
          "_id": {
            "bsonType": "objectId"
          },
          "productRef": {
            "bsonType": "string",
            "description": "Required & Unique: Internal SKU or autogenerated code"
          },
          "price": {
            "bsonType": "double",
            "minimum": 0,
            "description": "Required: Must be a non-negative double"
          },
          "name": {
            "bsonType": "string"
          },
          "description": {
            "bsonType": "string"
          },
          "imageUrl": {
            "bsonType": "string"
          },
          "shopRef": {
            "bsonType": "string",
            "description": "Required: Links this product to a specific shop"
          },
          "physicalStock": {
            "bsonType": "int",
            "minimum": 0,
            "description": "Required: The actual number of items on the shelf"
          },
          "reservedStock": {
            "bsonType": "int",
            "description": "Optional: Number of items locked for online orders"
          }
        }
      }
    },
    "m1-p13-nyavo-fitia.orders": {
      "ns": "m1-p13-nyavo-fitia.orders",
      "jsonSchema": {
        "bsonType": "object",
        "required": ["_id", "orderRef", "buyerId", "shopId", "items", "total", "status"],
        "properties": {
          "_id": { "bsonType": "objectId" },
          "orderRef": {
            "bsonType": "string",
            "description": "Required & Unique: Autogenerated reference for the customer (e.g., ORD-5521)"
          },
          "buyerId": { "bsonType": "string" },
          "shopId": { "bsonType": "string" },
          "items": {
            "bsonType": "array",
            "minItems": 1,
            "items": {
              "bsonType": "object",
              "required": ["productId", "quantity", "priceAtOrder"],
              "properties": {
                "productId": { "bsonType": "string" },
                "quantity": { "bsonType": "int", "minimum": 1 },
                "priceAtOrder": { "bsonType": "double" }
              }
            }
          },
          "total": { "bsonType": "double" },
          "status": {
            "enum": ["PENDING", "READY", "COMPLETED", "CANCELLED"],
            "description": "PENDING (Stock reserved), READY (Shop prepared it), COMPLETED (Customer picked it up)"
          }
        }
      }
    },
    "m1-p13-nyavo-fitia.stock_movement": {
      "ns": "m1-p13-nyavo-fitia.stock_movement",
      "jsonSchema": {
        "bsonType": "object",
        "required": ["_id", "mvtRef", "type", "performedBy", "items", "createdAt"],
        "properties": {
          "_id": { "bsonType": "objectId" },
          "mvtRef": {
            "bsonType": "string",
            "description": "Required & Unique: Autogenerated (e.g., MVT-2026-XYZ)"
          },
          "type": {
            "enum": ["IN", "OUT", "RESERVE", "UNRESERVE", "ADJUSTMENT"],
            "description": "IN: Restock, OUT: Sale, RESERVE: Online Order, UNRESERVE: Cancelled Order"
          },
          "sourceId": {
            "bsonType": "string",
            "description": "Optional: The ID of the Order or Sale that triggered this movement"
          },
          "performedBy": {
            "bsonType": "string",
            "description": "User ID of the shop owner or admin"
          },
          "createdAt": { "bsonType": "date" },
          "items": {
            "bsonType": "array",
            "minItems": 1,
            "items": {
              "bsonType": "object",
              "required": ["productId", "quantity"],
              "properties": {
                "productId": { "bsonType": "string" },
                "quantity": {
                  "bsonType": "int",
                  "description": "Negative for sales/reservations, positive for restocks"
                },
                "price" : { "bsonType": "double","minimum": 0 },
                "reason": { "bsonType": "string" }
              }
            }
          }
        }
      }
    },
    "m1-p13-nyavo-fitia.sales": {
      "ns": "m1-p13-nyavo-fitia.sales",
      "jsonSchema": {
        "bsonType": "object",
        "required": ["_id", "salesRef", "shopRef", "totalAmount", "channel", "paymentMethod", "items", "createdAt"],
        "properties": {
          "_id": { "bsonType": "objectId" },
          "salesRef": {
            "bsonType": "string",
            "description": "Required & Unique: Receipt number (e.g., REC-102938)"
          },
          "shopRef": { "bsonType": "string" },
          "totalAmount": { "bsonType": "double", "minimum": 0 },
          "orderRef": {
            "bsonType": "string",
            "description": "Optional: Only present if the sale originated from an online order"
          },
          "channel": {
            "enum": ["PHYSICAL_POS", "ONLINE_PLATFORM"],
            "description": "How the sale was made"
          },
          "paymentMethod": {
            "enum": ["CASH", "MOBILE_MONEY", "CARD"],
            "description": "Method of payment"
          },
          "createdAt": { "bsonType": "date" },
          "items": {
            "bsonType": "array",
            "minItems": 1,
            "items": {
              "bsonType": "object",
              "required": ["productId", "quantity", "priceAtSale"],
              "properties": {
                "productId": { "bsonType": "string" },
                "quantity": { "bsonType": "int", "minimum": 1 },
                "priceAtSale": { "bsonType": "double" }
              }
            }
          }
        }
      }
    }
  },
